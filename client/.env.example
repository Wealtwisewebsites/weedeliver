# WeeDeliver Client Environment Variables (Vite)

# Backend API URL (production) — leave blank for local dev (Vite proxy handles /api/*)
VITE_API_URL=

# Supabase (for image uploads via Supabase Storage)
# Get from: https://supabase.com/dashboard/project/[your-project]/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_STORAGE_BUCKET=weedeliver

# Yoco Public Key (for reference only — actual checkout is redirect-based via backend)
VITE_YOCO_PUBLIC_KEY=
