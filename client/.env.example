# ═══ WeeDeliver Client — Environment Variables ═══
# Copy this to .env and fill in your values

# ─── Supabase Storage (for image uploads) ─────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# ─── Yoco (client-side public key for popup payment widget) ───────────────
VITE_YOCO_PUBLIC_KEY="pk_live_..."

# ─── API Base URL (leave empty for Vite proxy in dev) ─────────────────────
# In production, Vercel needs this set to your Railway backend URL
VITE_API_URL="https://your-railway-backend.up.railway.app"