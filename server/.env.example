# ═══ WeeDeliver Server — Environment Variables ═══
# Copy this to .env and fill in your values

# ─── Database (REQUIRED) ───────────────────────────────────────────────────
# For production: Supabase Transaction Pooler URL
# Get from: https://supabase.com/dashboard → Project Settings → Database → Connection String (Transaction mode)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase Direct URL (for schema migrations — NOT the pooler)
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:[PASSWORD]@aws-0-[REGION].supabase.com:5432/postgres"

# ─── For local dev with SQLite ─────────────────────────────────────────────
# DATABASE_URL="file:./prisma/dev.db"   # Also change schema.prisma provider to "sqlite"
# DIRECT_URL=""

# ─── JWT Secrets (REQUIRED — generate with: openssl rand -hex 32) ──────────
JWT_SECRET="generate-with-openssl-rand-hex-32"
JWT_REFRESH_SECRET="generate-with-openssl-rand-hex-32-different"

# ─── AES-256 Encryption Key (REQUIRED — exactly 32 hex chars) ─────────────
ENCRYPTION_KEY="generate-with-openssl-rand-hex-16"

# ─── Yoco Payments (South Africa) ─────────────────────────────────────────
# Get from: https://portal.yoco.com → Developers → API Keys
YOCO_SECRET_KEY="sk_live_..."
YOCO_PUBLIC_KEY="pk_live_..."
YOCO_WEBHOOK_SECRET=""    # Set after configuring webhook URL in Yoco portal

# ─── Paystack (EFT payments) ───────────────────────────────────────────────
# Get from: https://dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=""

# ─── SnapScan (QR payments, optional) ─────────────────────────────────────
SNAPSCAN_API_KEY=""

# ─── SendGrid (email notifications, optional) ──────────────────────────────
SENDGRID_API_KEY=""

# ─── App Config ────────────────────────────────────────────────────────────
# Production client URL (your Vercel deployment)
CLIENT_URL="https://your-app.vercel.app"
PORT=3000
NODE_ENV="production"