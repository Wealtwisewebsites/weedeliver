# ═══ WeeDeliver Server — Environment Variables ═══
# Copy this file to .env and fill in your values

# Database (REQUIRED)
# Get a free PostgreSQL from: https://supabase.com or https://neon.tech or https://railway.app
DATABASE_URL="postgresql://postgres:password@localhost:5432/weedeliver?schema=public"

# JWT Secrets (REQUIRED — generate with: openssl rand -hex 32)
JWT_SECRET=""
JWT_REFRESH_SECRET=""

# AES-256 Encryption Key for banking details (REQUIRED — generate with: openssl rand -hex 16)
ENCRYPTION_KEY=""

# Yoco Payments (REQUIRED for card payments)
# Get keys at: https://yoco.com → Dashboard → Developers → API Keys
# Use sk_test_ / pk_test_ for testing, sk_live_ / pk_live_ for production
YOCO_SECRET_KEY=""
YOCO_PUBLIC_KEY=""

# Paystack (optional — for EFT payments)
# Get keys at: https://paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=""

# SnapScan (optional — for QR payments)
SNAPSCAN_API_KEY=""

# Cloudinary — Image uploads (REQUIRED for production)
# Sign up free at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# SendGrid — Email notifications (optional for MVP)
# Sign up at: https://sendgrid.com
SENDGRID_API_KEY=""

# Google OAuth (optional — for social login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google Maps (optional — for delivery tracking map)
GOOGLE_MAPS_API_KEY=""

# Twilio SMS/OTP (optional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# App Config
CLIENT_URL="http://localhost:5173"
PORT=3000
NODE_ENV="development"
